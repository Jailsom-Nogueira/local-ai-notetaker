# OpenAI is only used for the optional AI review step.
# Audio transcription stays local through whisper.cpp.
OPENAI_API_KEY=
NOTETAKER_REVIEW_MODEL=gpt-4.1-mini

# Local whisper.cpp setup.
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=./models/ggml-small.bin

# Local runtime data. This directory is intentionally git-ignored.
RECORDINGS_DIR=./data/recordings

# Upload/capture size cap per recording, in bytes. Default ~200 MB ≈ 2.4 hours
# at 192 kbps. Raise it for long sessions, e.g. 3 GB for a multi-hour workshop:
# MAX_AUDIO_BYTES=3221225472
MAX_AUDIO_BYTES=209715200

# Length in seconds of each transcription segment. Long audio is split into
# pieces of this size so whisper.cpp runs incrementally with progress.
NOTETAKER_SEGMENT_SECONDS=900

# Max characters per transcript window for map-reduce AI review. Transcripts
# longer than this are summarized in windows, then merged into one review.
NOTETAKER_REVIEW_MAP_CHARS=24000
